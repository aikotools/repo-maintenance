{
  "name": "@aikotools/repo-maintenance",
  "version": "0.0.0-semantic-release",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "repohub": "./bin/repohub.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "npx tsx --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:check": "tsc --noEmit",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,css,json}\"",
    "lint": "eslint \"{src,tests}/**/*.{ts,tsx}\"",
    "test": "pnpm lint && pnpm build && pnpm depcheck && vitest --run --coverage",
    "depcheck": "depcheck",
    "start": "node bin/repohub.js"
  },
  "dependencies": {
    "@hono/node-server": "1.19.10",
    "@tanstack/react-query": "5.90.21",
    "@trpc/client": "11.11.0",
    "@trpc/react-query": "11.11.0",
    "@trpc/server": "11.11.0",
    "@xyflow/react": "12.10.1",
    "hono": "4.12.4",
    "lucide-react": "0.576.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "simple-git": "3.32.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "9.2.1",
    "depcheck": "1.4.7",
    "eslint": "10.0.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
